# API Gateway base URL (all frontend requests go through the gateway)
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-long-random-secret-in-production

# Optional Google SSO (leave empty to use credentials only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
