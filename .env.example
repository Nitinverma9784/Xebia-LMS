# Root environment reference for Xebia LMS
# Copy module-specific files instead of this root file:
#
#   Backend/.env.example   → Backend/.env (optional)
#   frontend/.env.local.example → frontend/.env.local (required for Next.js)

# Quick reference — Backend
SPRING_PROFILES_ACTIVE=h2
DB_URL=jdbc:postgresql://localhost:5432/lms
DB_USERNAME=postgres
DB_PASSWORD=your-postgres-password
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Quick reference — Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-long-random-secret-in-production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
