# Copy to .env for local overrides (optional — Spring reads these as env vars)
# Do not commit .env

# Active profile: default (PostgreSQL) or h2 (in-memory, no Postgres required)
SPRING_PROFILES_ACTIVE=h2

# PostgreSQL (used when SPRING_PROFILES_ACTIVE is not h2)
DB_URL=jdbc:postgresql://localhost:5432/lms
DB_USERNAME=postgres
DB_PASSWORD=your-postgres-password

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Eureka & Config Server (defaults work for local dev)
# EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://localhost:8761/eureka/
# SPRING_CONFIG_IMPORT=optional:configserver:http://localhost:8888
